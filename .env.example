# Railway define PORT automaticamente.
# Nao fixe PORT no painel, a menos que necessario.

NODE_ENV=production

# Banco (Postgres Railway)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Sessao
SESSION_SECRET=troque-por-um-segredo-forte

# Descoberta entre servicos (private network Railway)
AUTH_SERVICE_HOST=
AUTH_SERVICE_PORT=3334
CLIENTS_SERVICE_HOST=
CLIENTS_SERVICE_PORT=3335
PETITIONS_SERVICE_HOST=
PETITIONS_SERVICE_PORT=3336

# Origem permitida no CORS
FRONTEND_URL=https://direitoeprovento.com.br
